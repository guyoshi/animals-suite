{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Animals Suite 1.0.13",
  "version": "1.0.13",
  "identifier": "com.gui.animals.planejador",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Animals Suite 1.0.13",
        "width": 1500,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "maximized": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Planejador e executor de produção do projeto Animals",
    "longDescription": "Suite integrada para planejar o jogo Animals, executar o roteiro de produção, consultar documentação técnica e acompanhar testes no Unity.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}
