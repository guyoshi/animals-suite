  "source": "using System.Collections;\n\n/// <summary>\n/// Classe-base de todas as ações executáveis num NpcEvent. As ações de um\n/// evento correm sequencialmente, em ordem, dentro de uma coroutine.\n///\n/// Para adicionar uma nova ação: cria uma subclasse [System.Serializable]\n/// e implementa Execute(). Ela aparece automaticamente no botão\n/// \"+ Adicionar Ação\" do Inspector do NpcController.\n/// </summary>\n[System.Serializable]\npublic abstract class NpcAction\n{\n    /// <summary>Executa a ação. Pode \"yield return\" para esperar (falas, movimento, espera, etc.).</summary>\n    public abstract IEnumerator Execute(NpcController npc);\n}\n",
